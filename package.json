{
  "name": "excalidraw-claymate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dai-shi/excalidraw-claymate.git"
  },
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "fix:format": "prettier -w .",
    "test": "pnpm run '/^test:.*/'",
    "test:type": "tsc",
    "test:lint": "eslint .",
    "test:format": "prettier -c .",
    "test:spec": "vitest run",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --project=chromium",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.1",
    "browser-fs-access": "^0.35.0",
    "gif.js": "^0.2.0",
    "lodash": "^4.18.1",
    "nanoid": "3.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "svg-to-excalidraw": "0.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/lodash": "^4.17.24",
    "@types/nanoid": "^3.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "canvas": "^3.2.3",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "6.0.0-rc.1",
    "jsdom": "^22.1.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  },
  "prettier": {
    "singleQuote": true
  }
}
